# ─────────────────────────────────────────────────────────────
#  DateMe — Environment Variables
#  Copy this file to ".env" and fill in your values.
#  NEVER commit your real .env file to git.
# ─────────────────────────────────────────────────────────────

# The app's sender email account (YOUR Gmail as the developer/admin).
# This is NOT the user's email — it's just the "From" address.
DATEME_EMAIL=youremail@gmail.com

# Gmail App Password (16 characters, spaces OK).
# Get one at: https://myaccount.google.com/apppasswords
# This is NOT your real Gmail password.
DATEME_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
