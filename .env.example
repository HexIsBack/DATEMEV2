# ─────────────────────────────────────────────────────────────────────────────
# DateMe — Environment Variables
# Copy this file to ".env" and fill in your real values.
# NEVER commit ".env" to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Django secret key (generate one at https://djecrety.ir/)
SECRET_KEY=your-secret-key-here


# ── EMAIL SETTINGS ────────────────────────────────────────────────────────────
# Choose ONE provider block below and fill in your credentials.
# Delete or comment out the others.

# ┌─ Option 1: Gmail ──────────────────────────────────────────────────────────
# Step 1 — Enable 2-Step Verification on your Google account:
#           https://myaccount.google.com/security
# Step 2 — Create an App Password:
#           https://myaccount.google.com/apppasswords
#           (Select "Mail" + "Windows Computer" or "Other")
# Step 3 — Paste the 16-character App Password below (no spaces).
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=DateMe <yourgmail@gmail.com>
# └────────────────────────────────────────────────────────────────────────────


# ┌─ Option 2: Outlook / Hotmail / Microsoft 365 ──────────────────────────────
# Use your normal Outlook password (or an App Password if MFA is on).
#
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@outlook.com
# EMAIL_HOST_PASSWORD=your-outlook-password
# DEFAULT_FROM_EMAIL=DateMe <you@outlook.com>
# └────────────────────────────────────────────────────────────────────────────


# ┌─ Option 3: Yahoo Mail ─────────────────────────────────────────────────────
# Create an App Password in Yahoo Account Security settings.
#
# EMAIL_HOST=smtp.mail.yahoo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@yahoo.com
# EMAIL_HOST_PASSWORD=your-yahoo-app-password
# DEFAULT_FROM_EMAIL=DateMe <you@yahoo.com>
# └────────────────────────────────────────────────────────────────────────────


# ┌─ Option 4: Development — print to terminal (no email sent) ─────────────────
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=DateMe <noreply@dateme.local>
# └────────────────────────────────────────────────────────────────────────────
